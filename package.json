{
    "name": "qubes-vscode",
    "displayName": "QubesOS Integration (unofficial)",
    "description": "Add QubesOS context menu actions to VSCode file explorer (copy/move to other qubes, open in disposable VM)",
    "version": "0.0.1",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/thom-gdpt/qubes-vscode"
    },
    "engines": {
        "vscode": "^1.118.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "qubes",
        "qubesos"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "qubes.copyToQube",
                "title": "Copy to other qube...",
                "category": "Qubes"
            },
            {
                "command": "qubes.moveToQube",
                "title": "Move to other qube...",
                "category": "Qubes"
            },
            {
                "command": "qubes.editInDisposable",
                "title": "Edit in disposable qube",
                "category": "Qubes"
            },
            {
                "command": "qubes.viewInDisposable",
                "title": "View in disposable qube",
                "category": "Qubes"
            },
            {
                "command": "qubes.convertPdf",
                "title": "Convert PDF in disposable qube",
                "category": "Qubes"
            },
            {
                "command": "qubes.convertImage",
                "title": "Convert image in disposable qube",
                "category": "Qubes"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "qubes.copyToQube",
                    "when": "qubes.isQubesOS",
                    "group": "qubes@1"
                },
                {
                    "command": "qubes.moveToQube",
                    "when": "qubes.isQubesOS",
                    "group": "qubes@1"
                },
                {
                    "command": "qubes.editInDisposable",
                    "when": "qubes.isQubesOS && !explorerResourceIsFolder",
                    "group": "qubes@2"
                },
                {
                    "command": "qubes.viewInDisposable",
                    "when": "qubes.isQubesOS && !explorerResourceIsFolder",
                    "group": "qubes@2"
                },
                {
                    "command": "qubes.convertPdf",
                    "when": "qubes.isQubesOS && !explorerResourceIsFolder && resourceExtname == .pdf",
                    "group": "qubes@3"
                },
                {
                    "command": "qubes.convertImage",
                    "when": "qubes.isQubesOS && !explorerResourceIsFolder && (resourceExtname == .png || resourceExtname == .jpg || resourceExtname == .jpeg || resourceExtname == .gif || resourceExtname == .bmp || resourceExtname == .tiff || resourceExtname == .tif || resourceExtname == .webp || resourceExtname == .svg)",
                    "group": "qubes@3"
                }
            ]
        },
        "configuration": {
            "title": "QubesOS Integration",
            "properties": {
                "qubes.showNotifications": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show notification messages when operations complete"
                },
                "qubes.autoDetect": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically detect if running on QubesOS"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "pretest": "npm run compile && npm run lint",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^25.x",
        "@types/vscode": "^1.118.0",
        "@vscode/vsce": "^3.9.1",
        "@typescript-eslint/eslint-plugin": "^8.x",
        "@typescript-eslint/parser": "^8.x",
        "eslint": "^10.x",
        "typescript": "^6.x"
    }
}